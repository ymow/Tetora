{
  "agents": {
    "zhuxuanbai": {
      "soulFile": "agents/zhuxuanbai/SOUL.md",
      "model": "sonnet",
      "permissionMode": "acceptEdits"
    },
    "zhouyu": {
      "soulFile": "agents/zhouyu/SOUL.md",
      "model": "sonnet",
      "permissionMode": "plan"
    },
    "zhangzhao": {
      "soulFile": "agents/zhangzhao/SOUL.md",
      "model": "sonnet",
      "permissionMode": "acceptEdits"
    },
    "luxun": {
      "soulFile": "agents/luxun/SOUL.md",
      "model": "sonnet",
      "permissionMode": "plan"
    },
    "taishici": {
      "soulFile": "agents/taishici/SOUL.md",
      "model": "sonnet",
      "permissionMode": "acceptEdits"
    },
    "ganning": {
      "soulFile": "agents/ganning/SOUL.md",
      "model": "sonnet",
      "permissionMode": "acceptEdits"
    },
    "guojia": {
      "soulFile": "agents/guojia/SOUL.md",
      "model": "sonnet",
      "permissionMode": "plan"
    },
    "zhanghong": {
      "soulFile": "agents/zhanghong/SOUL.md",
      "model": "sonnet",
      "description": "首席知識官與技術導師，專責撰寫教學、維護文檔與傳承經驗。",
      "permissionMode": "acceptEdits"
    }
  },
  "defaultAgent": "zhuxuanbai",
  "taskBoard": {
    "enabled": true,
    "autoDispatch": {
      "enabled": true,
      "interval": "2m"
    },
    "gitCommit": true,
    "gitWorktree": true
  },
  "providers": {
    "anthropic": {
      "apiKey": "$ANTHROPIC_API_KEY"
    }
  }
}
