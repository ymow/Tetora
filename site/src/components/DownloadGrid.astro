---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/utils';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const version = 'v2.2.3';
const base = `https://github.com/TakumaLee/Tetora/releases/download/${version}`;
const platforms = [
  { os: '🍎', label: 'macOS', arch: 'Apple Silicon (M1+)', file: `tetora-darwin-arm64` },
  { os: '🍎', label: 'macOS', arch: 'Intel', file: `tetora-darwin-amd64` },
  { os: '🐧', label: 'Linux', arch: 'x86_64', file: `tetora-linux-amd64` },
  { os: '🐧', label: 'Linux', arch: 'ARM64', file: `tetora-linux-arm64` },
  { os: '🪟', label: 'Windows', arch: 'x86_64', file: `tetora-windows-amd64.exe` },
];
---
<section id="download">
  <h2><span>{t(lang, 'dl_title')}</span></h2>
  <p style="text-align:center;color:var(--muted);margin-bottom:8px">{version} — {t(lang, 'latest')}</p>
  <div class="download-grid">
    {platforms.map(p => (
      <a href={`${base}/${p.file}`} class="dl-card">
        <span class="os">{p.os}</span>
        <span class="label">{p.label}</span>
        <span class="arch">{p.arch}</span>
      </a>
    ))}
  </div>
  <p style="text-align:center;margin-top:20px;font-size:13px;color:var(--muted)">
    {t(lang, 'or_script')}
    <code style="background:var(--surface);padding:3px 8px;border-radius:4px;font-size:12px;color:var(--green)">curl -fsSL https://tetora.dev/install.sh | bash</code>
  </p>
</section>
