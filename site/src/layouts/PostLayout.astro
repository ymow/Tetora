---
import Base from './Base.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/utils';
import { SITE } from '../consts';

interface Props {
  title: string;
  lang: Lang;
  date: string;
  tag: string;
  slug: string;
  description?: string;
  updatedDate?: string;
  section?: 'blog' | 'tips';
  alternates?: Array<{ lang: string; url: string }>;
  image?: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
}
const { title, lang, date, tag, slug, description, updatedDate, section = 'blog', alternates, image, headings } = Astro.props;
const sectionPath = `/${lang}/${section}/`;
const sectionLabel = t(lang, section === 'tips' ? 'nav_tips' : 'nav_blog');

const pagePath = `/${lang}/${section}/${slug}/`;
const canonicalUrl = `${SITE}${pagePath}`;
const homeUrl = lang === 'en' ? SITE : `${SITE}/${lang}`;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': section === 'blog' ? 'BlogPosting' : 'Article',
  headline: title,
  datePublished: date,
  dateModified: updatedDate ?? date,
  author: { '@type': 'Organization', name: 'Tetora', url: SITE },
  publisher: { '@type': 'Organization', name: 'Tetora', url: SITE },
  ...(description ? { description } : {}),
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', 'h2', '.prose p:first-of-type'],
  },
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Tetora', item: homeUrl },
    { '@type': 'ListItem', position: 2, name: sectionLabel, item: `${SITE}${sectionPath}` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
const h2Headings = headings?.filter(h => h.depth === 2) ?? [];
const howToJsonLd = section === 'tips' && h2Headings.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: title,
      ...(description ? { description } : {}),
      step: h2Headings.map((h, i) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: h.text,
        url: `${canonicalUrl}#${h.slug}`,
      })),
    }
  : null;
const jsonLd = howToJsonLd
  ? [articleJsonLd, breadcrumbJsonLd, howToJsonLd]
  : [articleJsonLd, breadcrumbJsonLd];
---
<Base
  title={`${title} — Tetora Blog`}
  lang={lang}
  ogType="article"
  ogUrl={canonicalUrl}
  canonicalUrl={canonicalUrl}
  description={description}
  ogImage={image ?? undefined}
  jsonLd={jsonLd}
  alternates={alternates}
>
  <LanguagePicker currentLang={lang} basePath={`/${section}/${slug}/`} />
  <nav style="padding:50px 20px 0;max-width:780px;margin:0 auto;font-size:13px;color:var(--muted)">
    <a href="/" style="color:var(--muted)">&larr; Tetora</a> / <a href={sectionPath} style="color:var(--muted)">{sectionLabel}</a>
  </nav>
  <article>
    <slot />
  </article>
  <Footer />
</Base>
