---
import PostLayout from '../../../layouts/PostLayout.astro';
import { languages } from '../../../i18n/ui';
import { getCollection, render } from 'astro:content';
import { SITE } from '../../../consts';

export async function getStaticPaths() {
  const tips = await getCollection('tips');
  const slugLangs = new Map<string, string[]>();
  for (const tip of tips) {
    const slug = tip.id.split('/').slice(1).join('/');
    const langs = slugLangs.get(slug) ?? [];
    langs.push(tip.data.lang);
    slugLangs.set(slug, langs);
  }
  return tips.map(tip => {
    const lang = tip.data.lang;
    const slug = tip.id.split('/').slice(1).join('/');
    return {
      params: { lang, slug },
      props: { tip, availableLangs: slugLangs.get(slug)! },
    };
  });
}

const { tip, availableLangs } = Astro.props;
const { Content, headings } = await render(tip);
const lang = tip.data.lang;
const slug = tip.id.split('/').slice(1).join('/');
const alternates = (availableLangs as string[]).map(l => ({
  lang: l,
  url: `${SITE}/${l}/tips/${slug}/`,
}));
---
<PostLayout
  title={tip.data.title}
  lang={lang}
  date={tip.data.date}
  tag="tips"
  slug={slug}
  section="tips"
  description={tip.data.description ?? tip.data.excerpt}
  alternates={alternates}
  headings={headings}
>
  <h1>{tip.data.title}</h1>
  <div class="article-meta">{tip.data.date}</div>
  <Content />
</PostLayout>
